{
  "name": "ExternalLinkClick",
  "type": "object",
  "properties": {
    "associate_id": {
      "type": "string",
      "description": "FK \u2192 Associate"
    },
    "product_id": {
      "type": "string",
      "description": "FK \u2192 Product (opcional, pode ser null para banners)"
    },
    "product_name": {
      "type": "string"
    },
    "banner_id": {
      "type": "string",
      "description": "FK \u2192 StoreBanner (opcional, pode ser null para produtos)"
    },
    "banner_name": {
      "type": "string"
    },
    "link_type": {
      "type": "string",
      "enum": [
        "product",
        "banner"
      ],
      "description": "Tipo de link clicado"
    },
    "status": {
      "type": "string",
      "enum": [
        "intent",
        "submitted",
        "approved",
        "rejected"
      ],
      "default": "intent",
      "description": "intent: clique registrado, submitted: compra enviada, approved: comiss\u00e3o confirmada"
    },
    "purchase_proof_url": {
      "type": "string",
      "description": "URL do comprovante de compra"
    },
    "purchase_amount": {
      "type": "number",
      "description": "Valor declarado da compra"
    },
    "commission_amount": {
      "type": "number",
      "description": "Valor da comiss\u00e3o a ser creditada"
    },
    "admin_notes": {
      "type": "string"
    },
    "clicked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "associate_id",
    "link_type"
  ]
}