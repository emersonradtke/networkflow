{
  "name": "AssociateRole",
  "type": "object",
  "properties": {
    "associate_id": {
      "type": "string",
      "description": "ID do associado"
    },
    "role_name": {
      "type": "string",
      "description": "Nome \u00fanico do role (ex: admin, associate, franchise)"
    },
    "assigned_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data/hora da atribui\u00e7\u00e3o do role"
    }
  },
  "required": [
    "associate_id",
    "role_name"
  ]
}