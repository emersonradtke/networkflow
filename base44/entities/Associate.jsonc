{
  "name": "Associate",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio vinculado"
    },
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "cpf": {
      "type": "string"
    },
    "cnpj": {
      "type": "string"
    },
    "company_name": {
      "type": "string",
      "description": "Raz\u00e3o social (PJ)"
    },
    "person_type": {
      "type": "string",
      "enum": [
        "pf",
        "pj"
      ],
      "default": "pf",
      "description": "Pessoa F\u00edsica ou Jur\u00eddica"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "inactive",
        "blocked",
        "awaiting_placement"
      ],
      "default": "pending"
    },
    "sponsor_id": {
      "type": "string",
      "description": "ID do associado que fez o convite"
    },
    "sponsor_name": {
      "type": "string"
    },
    "level_in_network": {
      "type": "number",
      "description": "N\u00edvel na rede do patrocinador"
    },
    "invite_code": {
      "type": "string",
      "description": "C\u00f3digo \u00fanico de convite"
    },
    "wallet_balance": {
      "type": "number",
      "default": 0
    },
    "total_earned": {
      "type": "number",
      "default": 0
    },
    "total_withdrawn": {
      "type": "number",
      "default": 0
    },
    "adhesion_paid": {
      "type": "boolean",
      "default": false
    },
    "adhesion_payment_id": {
      "type": "string"
    },
    "pix_key": {
      "type": "string"
    },
    "bank_info": {
      "type": "string"
    },
    "profile_image": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "shipping_street": {
      "type": "string",
      "description": "Endere\u00e7o de entrega - Rua"
    },
    "shipping_number": {
      "type": "string",
      "description": "Endere\u00e7o de entrega - N\u00famero"
    },
    "shipping_complement": {
      "type": "string"
    },
    "shipping_neighborhood": {
      "type": "string",
      "description": "Bairro"
    },
    "shipping_city": {
      "type": "string"
    },
    "shipping_state": {
      "type": "string"
    },
    "shipping_zip": {
      "type": "string",
      "description": "CEP de entrega"
    },
    "billing_same_as_shipping": {
      "type": "boolean",
      "default": true
    },
    "billing_street": {
      "type": "string",
      "description": "Endere\u00e7o de faturamento - Rua"
    },
    "billing_number": {
      "type": "string"
    },
    "billing_complement": {
      "type": "string"
    },
    "billing_neighborhood": {
      "type": "string"
    },
    "billing_city": {
      "type": "string"
    },
    "billing_state": {
      "type": "string"
    },
    "billing_zip": {
      "type": "string"
    },
    "addresses_completed": {
      "type": "boolean",
      "default": false,
      "description": "Se o associado j\u00e1 completou os endere\u00e7os"
    },
    "total_pontos": {
      "type": "number",
      "default": 0,
      "description": "Total de pontos acumulados"
    }
  },
  "required": [
    "full_name",
    "email"
  ]
}